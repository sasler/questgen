# GitHub OAuth (create at https://github.com/settings/applications/new)
GITHUB_ID=your_github_oauth_app_id
GITHUB_SECRET=your_github_oauth_app_secret

# NextAuth v5 secret (required for production)
# Generate with: openssl rand -base64 32
AUTH_SECRET=generate_with_openssl_rand_base64_32
# Backward compat: NEXTAUTH_SECRET is also accepted as a fallback
NEXTAUTH_URL=http://localhost:3000

# Upstash Redis (from https://console.upstash.com)
UPSTASH_REDIS_REST_URL=your_upstash_redis_url
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_token

# Optional: AUTH_TRUST_HOST=true (set in Vercel environment)

